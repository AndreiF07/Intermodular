<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="640.0" spacing="12.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.masaybrasa.controller.UserHomeController">
    <padding>
        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="bienvenidaLabel" text="Hola">
            <font>
                <javafx.scene.text.Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#onMisReservas" text="Mis reservas"/>
        <Button onAction="#onCerrarSesion" text="Cerrar sesion"/>
    </HBox>

    <Label text="Reservar mesa"/>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Fecha:"/>
        <DatePicker fx:id="fechaPicker"/>
        <Button onAction="#onBuscar" text="Buscar disponibles"/>
    </HBox>

    <TableView fx:id="mesasTable" prefHeight="280.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" prefWidth="120.0" text="Mesa #"/>
            <TableColumn fx:id="personasCol" prefWidth="200.0" text="Capacidad"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Button fx:id="reservarBtn" defaultButton="true" onAction="#onReservar" text="Reservar mesa seleccionada"/>
        <Label fx:id="statusLabel" textFill="DARKBLUE"/>
    </HBox>
</VBox>
