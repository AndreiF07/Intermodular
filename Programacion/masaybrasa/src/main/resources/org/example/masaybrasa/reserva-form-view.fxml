<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="380.0" prefWidth="380.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.masaybrasa.controller.ReservaFormController">
    <padding>
        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/>
    </padding>

    <Label fx:id="tituloLabel" text="Reserva">
        <font>
            <javafx.scene.text.Font name="System Bold" size="16.0"/>
        </font>
    </Label>

    <VBox spacing="4.0">
        <Label text="Fecha"/>
        <DatePicker fx:id="fechaPicker" maxWidth="Infinity"/>
    </VBox>
    <VBox spacing="4.0">
        <Label text="Hora (HH:mm)"/>
        <TextField fx:id="horaField" promptText="20:00"/>
    </VBox>
    <VBox spacing="4.0">
        <Label text="Estado"/>
        <ChoiceBox fx:id="estadoChoice" maxWidth="Infinity"/>
    </VBox>
    <VBox spacing="4.0">
        <Label text="Mesa"/>
        <ChoiceBox fx:id="mesaChoice" maxWidth="Infinity"/>
    </VBox>

    <Label fx:id="errorLabel" textFill="RED"/>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#onCancelar" text="Cancelar"/>
        <Button defaultButton="true" onAction="#onGuardar" text="Guardar"/>
    </HBox>
</VBox>
