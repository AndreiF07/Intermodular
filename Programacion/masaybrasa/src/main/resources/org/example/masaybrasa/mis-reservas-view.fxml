<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="640.0" spacing="12.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.masaybrasa.controller.MisReservasController">
    <padding>
        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Mis reservas">
            <font>
                <javafx.scene.text.Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#onVolver" text="Volver"/>
    </HBox>

    <TableView fx:id="reservasTable" prefHeight="360.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" prefWidth="80.0" text="ID"/>
            <TableColumn fx:id="fechaCol" prefWidth="220.0" text="Fecha y hora"/>
            <TableColumn fx:id="estadoCol" prefWidth="140.0" text="Estado"/>
            <TableColumn fx:id="mesaCol" prefWidth="120.0" text="Mesa"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Button defaultButton="true" onAction="#onCancelar" text="Cancelar reserva"/>
    </HBox>
</VBox>
