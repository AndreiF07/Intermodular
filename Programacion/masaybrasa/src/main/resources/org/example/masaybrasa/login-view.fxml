<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="360.0" prefWidth="420.0" spacing="12.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.masaybrasa.controller.LoginController">
    <padding>
        <Insets bottom="24.0" left="32.0" right="32.0" top="24.0"/>
    </padding>
    <Label text="Masa y Brasa">
        <font>
            <javafx.scene.text.Font name="System Bold" size="24.0"/>
        </font>
    </Label>
    <Label text="Iniciar sesion"/>

    <VBox spacing="6.0">
        <Label text="Correo"/>
        <TextField fx:id="correoField" promptText="correo@dominio.com"/>
    </VBox>

    <VBox spacing="6.0">
        <Label text="Telefono"/>
        <TextField fx:id="telefonoField" promptText="666123123"/>
    </VBox>

    <Label fx:id="errorLabel" textFill="RED"/>

    <HBox alignment="CENTER" spacing="12.0">
        <Button defaultButton="true" onAction="#onLogin" text="Entrar"/>
        <Button onAction="#onIrRegistro" text="Registrarse"/>
    </HBox>
</VBox>
