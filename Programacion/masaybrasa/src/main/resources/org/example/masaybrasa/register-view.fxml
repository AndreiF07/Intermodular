<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="460.0" prefWidth="420.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.masaybrasa.controller.RegisterController">
    <padding>
        <Insets bottom="24.0" left="32.0" right="32.0" top="24.0"/>
    </padding>

    <Label text="Crear cuenta">
        <font>
            <javafx.scene.text.Font name="System Bold" size="20.0"/>
        </font>
    </Label>

    <VBox spacing="4.0">
        <Label text="Nombre"/>
        <TextField fx:id="nombreField"/>
    </VBox>
    <VBox spacing="4.0">
        <Label text="Apellido"/>
        <TextField fx:id="apellidoField"/>
    </VBox>
    <VBox spacing="4.0">
        <Label text="Correo"/>
        <TextField fx:id="correoField"/>
    </VBox>
    <VBox spacing="4.0">
        <Label text="Telefono"/>
        <TextField fx:id="telefonoField"/>
    </VBox>

    <Label fx:id="errorLabel" textFill="RED"/>

    <HBox alignment="CENTER" spacing="12.0">
        <Button defaultButton="true" onAction="#onRegistrar" text="Registrar"/>
        <Button onAction="#onVolver" text="Volver"/>
    </HBox>
</VBox>
